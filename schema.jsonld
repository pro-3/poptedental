    {
      "@type": "FAQPage",
      "@id": "https://poptedental.in/#faq",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Do I need an appointment, or can I walk in?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Walk-ins are welcome, but booking an appointment through our form or WhatsApp helps us plan your visit and reduce your waiting time."
          }
        },
        {
          "@type": "Question",
          "name": "Is root canal treatment painful?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Modern root canal treatment is done under local anaesthesia, so the procedure itself is virtually painless. Most patients feel only mild sensitivity afterward."
          }
        },
        {
          "@type": "Question",
          "name": "Do you treat children?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, we welcome patients of all ages, including children. We take extra care to keep young patients comfortable during their visit."
          }
        },
        {
          "@type": "Question",
          "name": "How much does a dental implant cost?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Implant cost depends on your specific case. Visit the clinic for a consultation and Dr. Popte will explain the options and pricing clearly."
          }
        },
        {
          "@type": "Question",
          "name": "Do you accept emergency dental cases?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. For urgent tooth pain or dental emergencies, call the clinic directly and we'll try to accommodate you as soon as possible."
          }
        }
      ]
